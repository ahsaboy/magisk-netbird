#!/sbin/sh

#################
# Initialization
#################

umask 022

# echo before loading util_functions.sh
ui_print() { echo "$1"; }

require_new_magisk() {
  ui_print "*******************************"
  ui_print " Please install Magisk v20.4+! "
  ui_print "*******************************"
  exit 1
}

#########################
# Load util_functions.sh
#########################

OUTFD=$2
ZIPFILE=$3

mount /data 2>/dev/null

# Support both Magisk and KernelSU
if [ -f /data/adb/magisk/util_functions.sh ]; then
  . /data/adb/magisk/util_functions.sh
  [ $MAGISK_VER_CODE -lt 20400 ] && require_new_magisk
elif [ -d /data/adb/ksu ]; then
  # KernelSU provides its own util_functions when installed via KSU Manager
  [ -f /data/adb/ksu/bin/ksud ] || require_new_magisk
else
  require_new_magisk
fi

install_module
exit 0
